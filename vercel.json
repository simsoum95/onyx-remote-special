{
    "functions": {
        "api/ha.js": { "maxDuration": 15 },
        "api/plex.js": { "maxDuration": 25 }
    },
    "rewrites": [
        { "source": "/api/ha", "destination": "/api/ha" },
        { "source": "/api/plex", "destination": "/api/plex" },
        { "source": "/((?!api).*)", "destination": "/index.html" }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
            ]
        }
    ]
}
